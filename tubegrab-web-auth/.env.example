# Access control for protected website
AUTH_USERNAME=your-id
AUTH_PASSWORD=your-strong-password
AUTH_REALM=TubeGrab Protected
AUTH_MAX_FAILURES=10
AUTH_BLOCK_MINUTES=15

# Optional runtime settings
PORT=3000
YT_DLP_PATH=yt-dlp
TRUST_PROXY=1
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
GLOBAL_RATE_LIMIT_MAX=120
DOWNLOAD_RATE_LIMIT_MAX=8
DOWNLOAD_START_RATE_LIMIT_MAX=60
MAX_PLAYLIST_ENTRIES=50
MAX_CONCURRENT_JOBS=25
